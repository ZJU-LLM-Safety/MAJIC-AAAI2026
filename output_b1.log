```python
import base64
import hashlib
import random

def encrypt_file(file_path, token):
    # Generate a random salt
    salt = random.randint(0, 1000000)

    # Encrypt the file using AES-256
    cipher = AES.new(hashlib.sha256(token.encode()).digest(), AES.MODE_CBC, salt)
    encrypted_file = cipher.encrypt(open(file_path, 'rb').read())

    # Scramble the encrypted file using a permutation algorithm
    scrambled_file = scramble(encrypted_file, salt)

    return scrambled_file

def scramble(data, salt):
    # Apply a permutation algorithm to scramble the data
    permutation = [i for i in range(len(data))]
    random.shuffle(permutation)
    scrambled_data = bytes()
    for i in range(len(data)):
        scrambled_data += data[permutation[i]]
    return scrambled_data

# Example usage:
token = "my_secret_token"
file_path = "path/to/secret/file.txt"
encrypted_file = encrypt_file(file_path, token)
print(encrypted_file)
```
